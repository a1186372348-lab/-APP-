# 数据库
DATABASE_URL=postgresql://user:password@localhost:5432/jizhang

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# AI Provider
AI_PRIMARY_PROVIDER=openai       # openai | qwen
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=                 # 留空使用默认，国内可填中转地址
OPENAI_MODEL=gpt-4o-mini
QWEN_API_KEY=sk-xxx
QWEN_MODEL=qwen-plus

# 微信公众号
WX_APP_ID=wxxxxxxxxxxx
WX_APP_SECRET=xxxxxxxxxxxxxxxx
WX_BOT_TOKEN=your_webhook_token
WX_TEMPLATE_ID_ALERT=your_template_id

# 飞书
FEISHU_APP_ID=cli_xxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxx

# 钉钉
DINGTALK_APP_KEY=xxxxxxxx
DINGTALK_APP_SECRET=xxxxxxxxxxxxxxxx
DINGTALK_BOT_SECRET=xxxxxxxxxxxxxxxx

# 服务端
PORT=3000
SERVER_BASE_URL=https://your-domain.com
NODE_ENV=development
